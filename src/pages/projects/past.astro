---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const title = "Past Research | Landon Green";
const description = "My past experience and research.";
---
<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <h1>Past Projects & Research</h1>
            </section>
            
            <hr />

            <div class="prose">
                <h3>Guild Associate Internship</h3>
                <h5>Time: April 2025-May 2025 (3 weeks long)</h5>
                <ul>
                    <li>Created schematics and did routine equipment checks.</li>
                    <li>Sat in on meetings regarding safety, sales, and optimization.</li>
                    <li>Worked in groups and alone to solve engineering related problems with programs and machines.</li>
                </ul>

                <h3>Damage INC. Volunteer Work</h3>
                <h5>Time: April 2023 - December 2023 (8 months long)</h5>
                <ul>
                    <li>Team leader for groups of 30+ at a time and supervised their progress and tasks.</li>
                    <li>Managed and hosted events.</li>
                    <li>Participated in meetings to optimize and improve the organization as a whole.</li>
                </ul>

                <h3>Other Notable Mentions</h3>
                <ul>
                    <li>National Honors Society (September 2025 - May 2025)</li>
                </ul>
            </div>
            <div class="cta">
                <p>Interested in collaborating on a project or discussing research?</p>
                <a href="mailto:thelandonjgreen@gmail.com" class="contact-button">Reach Out</a>
            </div>
        </main>
        <Footer />
    </body>
</html>