---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Landon Green</h1>
				<h3>Pre-Mechanical Engineering @ The Ohio State University</h3>
				<p class="tagline">
					Building systems, studying philosophy, and training for peak performance.
				</p>
			</section>

			<hr />

			<section class="grid">
				<div class="card">
					<h4>🛠️ Engineering</h4>
					<p>Focusing on Physics and Calculus II/III. Exploring the intersection of CAD and hands-on design.</p>
				</div>
				<div class="card">
					<h4>🔥 Discipline</h4>
					<p>Currently focused on a training regiment balancing running, rucking, cardio, strength, and muscle.</p>
				</div>
				<div class="card">
					<h4>🥁 Creative</h4>
					<p>Learning to play drums, design my own website, and copywriting/sales on the side.</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>