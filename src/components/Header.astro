---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
    <nav>
        <h2><a href="/">{SITE_TITLE}</a></h2>
        <div class="internal-links">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            
        <div class="dropdown">
        <div class="dropdown-trigger-container">
            <HeaderLink href="/projects" class="dropdown-link">
            Projects
            </HeaderLink>
            <button class="dropdown-caret" aria-label="Toggle Submenu">
            <span class="arrow">▼</span>
            </button>
        </div>
        
        <div class="dropdown-content">
            <a href="/projects/current">Current Research</a>
            <a href="/projects/past">Past Experience</a>
            <a href="/projects/personal">Personal & Hobbies</a>
        </div>
        </div>

            <HeaderLink href="/philosophy">Philosophy</HeaderLink>
            <HeaderLink href="/about">About</HeaderLink>
        </div>
        <div>
            <button id="theme-toggle" aria-label="Toggle theme">
            <!-- Sun Icon (Visible in Dark Mode) -->
            <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M22 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
            <!-- Moon Icon (Visible in Light Mode) -->
            <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
            </button>
        </div>
        <div class="social-links">
            <a href="https://www.linkedin.com/in/landonjgreen" target="_blank">
                <span class="sr-only">Follow me on LinkedIn</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256">
                    <path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z"></path>
                </svg>
            </a>
            <a href="https://github.com/landonjgreen" target="_blank">
                <span class="sr-only">Go to my GitHub Page</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
                    <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
                </svg>
            </a>
        </div>
    </nav>
</header>

<style is:global>
    header {
        margin: 0;
        padding: 1rem 2rem;
        background: var(--background)
        box-shadow: 0 2px 8px rgba(var(--black), 5%);
        width: 100%;
        box-sizing: border-box;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    header nav {
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        gap: 1.5rem;
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
        justify-content: space-between;
    }
    h2 {
        margin: 0;
        font-size: 1em;
        white-space: nowrap;
    }
    h2 a,
    h2 a.active {
        text-decoration: none !important;
    }
    @media (max-width: 768px) {
    .dropdown {
        position: relative;
    }
    .dropdown-content {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background-color: var(--background);
        z-index: 10;
        min-width: 160px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(var(--black), 10%);
    }
    .dropdown.is-open .dropdown-content {
        display: flex;
        flex-direction: column;
    }
    }
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    /* FORCE REMOVE BLACK LINES */
    nav a,
    nav a:visited,
    nav a:hover,
    nav a.active {
        padding: 1em 0.5em;
        color: var(--text);
        text-decoration: none !important; /* Forces black line gone */
        text-decoration-line: none !important;
        border-bottom: 4px solid transparent;
    }
    nav a.active {
        border-bottom-color: var(--accent); /* Keeps clean red line */
    }
    
    /* Dropdown Styles */
    .dropdown {
        position: relative;
        display: inline-block;
    }
    .dropdown-content {
        display: none;
        position: absolute;
        color: var(--text) !important;
        text decoration: none !important;
        background-color: var(--background) !important;
        background: var(--background) !important;
        min-width: 180px;
        box-shadow: 0px 8px 16px rgba(0,0,0,0.1);
        z-index: 99;
        border-radius: 4px;
        top: 100%;
        left: 0;
        border-bottom: none !important;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }
    .dropdown-content a {
        color: var(--text) !important;
        background-color: var(--background) !important;
        padding: 0.75em 1em;
        text-decoration: none !important;
        display: block;
        font-size: 0.9em;
        border-bottom: none !important;
        text-align: left;
    }
    .dropdown-content a:hover {
        background-color: var(--background)
        color: var(--accent);
    }
    
    /* Desktop hover only (stops mobile fight) */
    @media (min-width: 769px) {
        .dropdown:hover .dropdown-content {
            display: block;
        }
    }
    
    .arrow {
        font-size: 0.6em;
        vertical-align: middle;
        margin-left: 1px;
    }

    .social-links,
    .social-links a {
        display: flex;
    }
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    @media (max-width: 720px) {
        .social-links {
            display: none;
        }
    }
    .dropdown-caret {
        background: none;
        border: none;
        padding: 0;
        margin-left: 4px;
        color: inherit;
        font-size: 0.75em;
        cursor: pointer;
        vertical-align: middle;
    }
    /* Erase the black underline from name header links */
header h2 a,
header h2 a:hover,
header h2 a:active,
header h2 a:focus,
header h2 a.active {
    text-decoration: none !important;
    text-decoration-line: none !important;
    border-bottom: none !important;
}

/* Erase the black underline from the main Projects link when active */
header nav .dropdown .dropdown-trigger,
header nav .dropdown a,
header nav .dropdown a:hover,
header nav .dropdown a:active,
header nav .dropdown a:focus,
header nav .dropdown a.active {
    text-decoration: none !important;
    text-decoration-line: none !important;
}
/* Default Light Theme colors */
:root {
  --background: #ffffff;
  --text: #111111;
  --black: 17, 17, 17; /* Used for your box shadows */
}

/* Dark Theme colors */
:root[data-theme="dark"] {
  --background: #121212;
  --text: #f4f4f4;
  --black: 0, 0, 0;
}

/* Apply the variables globally */
body {
  background-color: var(--background);
  color: var(--text);
  transition: background-color 0.3s ease, color 0.3s ease; /* Smooth transition */
}

/* Button & Icon Styles */
#theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  color: var(--text) !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

#theme-toggle svg {
    stroke: currentColor; /* Forces the SVG lines to use the text color */
    fill: none;
}

/* Toggle icon visibility based on the active theme */
:root[data-theme="dark"] .sun-icon { display: block; }
:root[data-theme="dark"] .moon-icon { display: none; }

:root:not([data-theme="dark"]) .sun-icon { display: none; }
:root:not([data-theme="dark"]) .moon-icon { display: block; }
</style>
<script>
  // Handle mobile arrow toggle (Open and Close)
  document.querySelectorAll('.dropdown-caret').forEach(caret => {
    caret.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      const dropdown = caret.closest('.dropdown');
      if (dropdown) {
        dropdown.classList.toggle('is-open');
      }
    });
  });

  // Kill the menu flash when clicking the text link
  document.querySelectorAll('.dropdown-trigger').forEach(link => {
    link.addEventListener('click', () => {
      const dropdown = link.closest('.dropdown');
      if (dropdown) {
        dropdown.classList.remove('is-open');
      }
    });
  });

  // Close menu if user taps completely outside of it
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.dropdown')) {
      document.querySelectorAll('.dropdown.is-open').forEach(dropdown => {
        dropdown.classList.remove('is-open');
      });
    }
  });
</script>
<script>
  const handleToggle = () => {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    toggle.addEventListener('click', () => {
      const element = document.documentElement;
      const isDark = element.getAttribute('data-theme') === 'dark';
      
      if (isDark) {
        element.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        element.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  };

  // Runs on initial load
  handleToggle();

  // Runs on view transitions if you use Astro's <ViewTransitions /> component
  document.addEventListener('astro:after-swap', handleToggle);
</script>
